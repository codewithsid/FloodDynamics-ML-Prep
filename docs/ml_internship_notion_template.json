    }
  ],
  "suggested_views": [
    {
      "database": "ML Internship Roadmap",
      "name": "By Focus Area",
      "group_by": "Focus Area"
    },
    {
      "database": "Daily Build Log",
      "name": "This Week",
      "filter": "Date is within the next/past 7 days"
    },
    {
      "database": "ML Projects",
      "name": "Active Only",
      "filter": "Status is not Done"
    }
  ]
