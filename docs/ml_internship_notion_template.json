          "Demo Ready?": false
        },
        {
          "Project Name": "ML API",
          "Type": "Systems",
          "Description": "Serve a trained model behind a FastAPI endpoint and document how to run it locally.",
          "Tech Stack": "Python, FastAPI, Uvicorn, Docker",
          "Status": "Not Started",
          "GitHub Repo": "",
          "Demo Ready?": false
